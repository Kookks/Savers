{% comment %}
  ============================================================
  Savers – Custom Product Page Section (v3)
  Theme: Dawn 15.x
  Changes from expert review:
    - Thumbnail carousel (1 line, scrollable)
    - 3 selling points under title
    - ATC only (no WhatsApp CTA)
    - 3 trust badges on 1 line
    - Visual features/how-it-works with image placeholders
    - Judge.me review widget instead of static reviews
  ============================================================
{% endcomment %}

{%- liquid
  assign current_var   = product.selected_or_first_available_variant
  assign compare_price = current_var.compare_at_price
  assign sale_price    = current_var.price
  assign on_sale       = false
  if compare_price > sale_price
    assign on_sale = true
  endif
  assign discount_pct = 0
  if on_sale and compare_price > 0
    assign discount_pct = compare_price | minus: sale_price | times: 100 | divided_by: compare_price
  endif
-%}

<style>
  :root {
    --cp-yellow:#FAE10A; --cp-yellow-dk:#D4BC00;
    --cp-black:#111; --cp-white:#FFF; --cp-bg:#FAFAFA;
    --cp-text:#111; --cp-muted:#666; --cp-light:#999;
    --cp-border:#E8E8E8; --cp-green:#22C55E; --cp-danger:#EF4444;
    --cp-r-sm:6px; --cp-r-md:12px; --cp-r-lg:20px; --cp-r-pill:999px;
    --cp-shadow:0 4px 16px rgba(0,0,0,.1);
    --cp-font:'Inter',system-ui,sans-serif;
  }
  .cp *,.cp *::before,.cp *::after{box-sizing:border-box;word-break:break-word;overflow-wrap:anywhere}
  .cp{font-family:var(--cp-font);color:var(--cp-text);line-height:1.6;width:100%;overflow-x:hidden;max-width:100vw}
  .cp img{max-width:100%;display:block}
  .cp-mx{max-width:1200px;margin:0 auto;width:100%}

  /* ─── Product Grid ─── */
  .cp-product{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;padding:24px 24px 64px}
  /* min-width:0 is CRITICAL — grid children don't shrink below content size by default */
  .cp-gallery,.cp-info{min-width:0;width:100%}

  /* ─── Gallery ─── */
  .cp-gallery{position:sticky;top:80px}
  .cp-main-img{aspect-ratio:1/1;background:var(--cp-white);border-radius:var(--cp-r-lg);border:1px solid var(--cp-border);overflow:hidden;position:relative;margin-bottom:10px}
  .cp-main-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
  .cp-main-img:hover img{transform:scale(1.04)}
  .cp-sale-tag,.cp-sold-tag{position:absolute;top:14px;left:14px;font-size:11px;font-weight:700;padding:4px 10px;border-radius:var(--cp-r-pill);letter-spacing:.5px;text-transform:uppercase}
  .cp-sale-tag{background:var(--cp-yellow);color:var(--cp-black)}
  .cp-sold-tag{background:var(--cp-danger);color:#fff}

  /* Thumbnail carousel */
  .cp-thumbs-wrap{position:relative;overflow:hidden}
  .cp-thumbs{display:flex;gap:8px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding:2px 0}
  .cp-thumbs::-webkit-scrollbar{display:none}
  .cp-thumb{flex:0 0 72px;height:72px;border-radius:var(--cp-r-sm);border:2px solid var(--cp-border);overflow:hidden;cursor:pointer;transition:border-color .2s;scroll-snap-align:start}
  .cp-thumb.active{border-color:var(--cp-black)}
  .cp-thumb:hover{border-color:#aaa}
  .cp-thumb img{width:100%;height:100%;object-fit:cover}
  .cp-thumb-arrow{position:absolute;top:50%;transform:translateY(-50%);width:28px;height:28px;background:rgba(255,255,255,.9);border:1px solid var(--cp-border);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;cursor:pointer;z-index:2;transition:background .2s;box-shadow:0 1px 4px rgba(0,0,0,.1)}
  .cp-thumb-arrow:hover{background:var(--cp-yellow)}
  .cp-thumb-arrow.left{left:0}
  .cp-thumb-arrow.right{right:0}

  /* ─── Info ─── */
  .cp-info{padding-top:4px}
  .cp-badges{display:flex;gap:8px;margin-bottom:10px}
  .cp-badge{font-size:11px;font-weight:700;padding:4px 10px;border-radius:var(--cp-r-pill);letter-spacing:.5px;text-transform:uppercase}
  .cp-b-yellow{background:var(--cp-yellow);color:var(--cp-black)}
  .cp-b-dark{background:var(--cp-black);color:var(--cp-white)}
  .cp-b-green{background:#D1FAE5;color:#065F46}
  .cp-b-red{background:#FEE2E2;color:#991B1B}
  .cp-title{font-size:28px;font-weight:800;line-height:1.2;letter-spacing:-.3px;margin-bottom:12px}

  /* Selling points */
  .cp-usps{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
  .cp-usp{display:flex;align-items:center;gap:10px;font-size:14px;font-weight:500;color:var(--cp-text)}
  .cp-usp-icon{flex:0 0 24px;height:24px;background:var(--cp-yellow);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px}

  .cp-rating{display:flex;align-items:center;gap:8px;margin-bottom:16px}
  .cp-stars{color:#F59E0B;font-size:14px}
  .cp-rating-text{font-size:13px;color:var(--cp-muted)}
  .cp-rating-sold{font-size:13px;color:var(--cp-muted);padding-left:8px;border-left:1px solid var(--cp-border)}

  .cp-price{display:flex;align-items:baseline;gap:10px;padding:14px 0;border-top:1px solid var(--cp-border);border-bottom:1px solid var(--cp-border);margin-bottom:20px}
  .cp-now{font-size:32px;font-weight:800}
  .cp-was{font-size:17px;color:var(--cp-light);text-decoration:line-through}
  .cp-save{background:#FEE2E2;color:#991B1B;font-size:12px;font-weight:700;padding:3px 8px;border-radius:var(--cp-r-pill)}

  /* Variants */
  .cp-variants{margin-bottom:18px}
  .cp-var-label{font-size:13px;font-weight:600;margin-bottom:8px;display:flex;align-items:center;gap:6px}
  .cp-var-opts{display:flex;gap:8px;flex-wrap:wrap}
  .cp-var-opts .swatch-btn{padding:7px 14px;border-radius:var(--cp-r-sm);border:2px solid var(--cp-border);font-size:13px;font-weight:500;background:var(--cp-white);cursor:pointer;transition:all .2s;color:var(--cp-text);font-family:var(--cp-font)}
  .cp-var-opts .swatch-btn:hover{border-color:#aaa}
  .cp-var-opts .swatch-btn.active{border-color:var(--cp-black);background:var(--cp-black);color:var(--cp-white)}

  .cp-qty-row{display:flex;align-items:center;gap:14px;margin-bottom:16px}
  .cp-qty-label{font-size:13px;font-weight:600}
  .cp-qty-ctrl{display:flex;align-items:center;border:2px solid var(--cp-border);border-radius:var(--cp-r-sm);overflow:hidden}
  .cp-qty-btn{width:38px;height:38px;background:var(--cp-bg);font-size:17px;display:flex;align-items:center;justify-content:center;cursor:pointer;border:none;font-family:var(--cp-font);transition:background .2s}
  .cp-qty-btn:hover{background:var(--cp-border)}
  .cp-qty-num{width:44px;height:38px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;border-left:2px solid var(--cp-border);border-right:2px solid var(--cp-border)}

  /* Urgency */
  .cp-urgency{display:flex;align-items:center;gap:10px;padding:10px 14px;background:#FFF8DC;border:1px solid #F0D800;border-radius:var(--cp-r-md);margin-bottom:16px}
  .cp-pulse{width:9px;height:9px;background:var(--cp-danger);border-radius:50%;animation:cpP 1.5s infinite;flex-shrink:0}
  @keyframes cpP{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.4)}50%{box-shadow:0 0 0 6px rgba(239,68,68,0)}}
  .cp-urgency span{font-size:13px;font-weight:600;color:#92400E}

  /* ATC */
  .cp-atc-wrap{margin-bottom:16px}
  .cp-atc{width:100%;padding:16px;border-radius:var(--cp-r-md);font-size:15px;font-weight:700;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;font-family:var(--cp-font);background:var(--cp-yellow);color:var(--cp-black);transition:all .2s;letter-spacing:.3px}
  .cp-atc:hover{background:var(--cp-yellow-dk);transform:translateY(-1px);box-shadow:0 4px 12px rgba(250,225,10,.4)}
  .cp-atc[disabled]{opacity:.5;cursor:not-allowed;transform:none}

  /* 3 Trust Badges */
  .cp-trust{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px}
  .cp-trust-item{text-align:center;padding:12px 6px;background:var(--cp-bg);border-radius:var(--cp-r-md);border:1px solid var(--cp-border)}
  .cp-trust-icon{font-size:20px;margin-bottom:2px}
  .cp-trust-text{font-size:10px;font-weight:600;line-height:1.3;color:var(--cp-muted)}

  /* Accordion */
  .cp-accordion{border-top:1px solid var(--cp-border);margin-top:24px}
  .cp-acc-item{border-bottom:1px solid var(--cp-border)}
  .cp-acc-hd{width:100%;display:flex;justify-content:space-between;align-items:center;padding:14px 0;background:none;font-size:14px;font-weight:600;color:var(--cp-text);cursor:pointer;text-align:left;border:none;font-family:var(--cp-font)}
  .cp-acc-ico{font-size:18px;transition:transform .3s;color:var(--cp-muted)}
  .cp-acc-item.open .cp-acc-ico{transform:rotate(45deg)}
  .cp-acc-body{font-size:14px;color:var(--cp-muted);line-height:1.7;max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s}
  .cp-acc-item.open .cp-acc-body{max-height:600px;padding-bottom:14px}

  /* ═══════════════════════════════════════ */
  /*  BELOW THE FOLD — Visual Sections      */
  /* ═══════════════════════════════════════ */

  /* Split Feature Row */
  .cp-split{padding:80px 24px}
  .cp-split-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
  /* min-width:0 on split children too — same grid shrink issue */
  .cp-split-inner > *{min-width:0}
  .cp-split.reverse .cp-split-inner{direction:rtl}
  .cp-split.reverse .cp-split-inner > *{direction:ltr}
  .cp-split-media{aspect-ratio:4/3;border-radius:var(--cp-r-lg);overflow:hidden;background:var(--cp-border);position:relative}
  .cp-split-media img,.cp-split-media video{width:100%;height:100%;object-fit:cover}
  .cp-split-media .cp-placeholder{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--cp-light);font-size:13px;font-weight:500;background:linear-gradient(135deg,#f5f5f5,#e8e8e8)}
  .cp-split-media .cp-placeholder .ph-icon{font-size:36px;opacity:.5}
  .cp-eyebrow{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--cp-yellow-dk);margin-bottom:8px}
  .cp-sec-title{font-size:28px;font-weight:800;line-height:1.2;letter-spacing:-.3px;margin-bottom:12px;color:var(--cp-text)}
  .cp-sec-desc{font-size:15px;color:var(--cp-muted);line-height:1.7;margin-bottom:20px}
  .cp-check-list{display:flex;flex-direction:column;gap:8px}
  .cp-check{display:flex;align-items:center;gap:10px;font-size:14px;font-weight:500}
  .cp-check-dot{flex:0 0 22px;height:22px;background:var(--cp-yellow);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px}

  .cp-split-dark{background:var(--cp-black);color:var(--cp-white)}
  .cp-split-dark .cp-sec-title{color:var(--cp-white)}
  .cp-split-dark .cp-sec-desc{color:rgba(255,255,255,.55)}
  .cp-split-dark .cp-check{color:rgba(255,255,255,.8)}
  .cp-split-dark .cp-eyebrow{color:var(--cp-yellow)}

  /* How It Works — with images */
  .cp-hiw{background:var(--cp-bg);padding:80px 24px}
  .cp-hiw-header{text-align:center;margin-bottom:48px}
  .cp-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .cp-step-card{background:var(--cp-white);border:1px solid var(--cp-border);border-radius:var(--cp-r-lg);overflow:hidden;transition:box-shadow .3s,transform .3s}
  .cp-step-card:hover{box-shadow:var(--cp-shadow);transform:translateY(-3px)}
  .cp-step-img{aspect-ratio:3/2;background:linear-gradient(135deg,#f5f5f5,#e8e8e8);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;color:var(--cp-light);font-size:12px;font-weight:500;position:relative}
  .cp-step-img .ph-icon{font-size:28px;opacity:.5}
  .cp-step-img img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
  .cp-step-num{position:absolute;top:12px;left:12px;width:32px;height:32px;background:var(--cp-yellow);color:var(--cp-black);border-radius:50%;font-size:14px;font-weight:800;display:flex;align-items:center;justify-content:center;z-index:1}
  .cp-step-body{padding:20px}
  .cp-step-body h3{font-size:16px;font-weight:700;margin-bottom:6px}
  .cp-step-body p{font-size:13px;color:var(--cp-muted);line-height:1.6}

  /* Video Section */
  .cp-video-section{background:var(--cp-black);padding:80px 24px;text-align:center}
  .cp-video-wrap{max-width:800px;margin:0 auto}
  .cp-video-container{aspect-ratio:16/9;background:#222;border-radius:var(--cp-r-lg);overflow:hidden;margin-top:32px;display:flex;align-items:center;justify-content:center;position:relative;border:1px solid rgba(255,255,255,.1)}
  .cp-video-container video,.cp-video-container iframe{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
  .cp-play-btn{width:72px;height:72px;background:var(--cp-yellow);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;cursor:pointer;transition:transform .2s;z-index:2;border:none}
  .cp-play-btn:hover{transform:scale(1.1)}

  /* Reviews — Judge.me widget area */
  .cp-reviews-section{padding:80px 24px;background:var(--cp-white)}
  .cp-reviews-header{text-align:center;margin-bottom:40px}
  .cp-judgeme-widget{max-width:1000px;margin:0 auto;min-height:200px}

  /* Sticky Bar */
  .cp-sticky{position:fixed;bottom:0;left:0;right:0;background:var(--cp-white);border-top:1px solid var(--cp-border);padding:10px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;box-shadow:0 -4px 20px rgba(0,0,0,.1);z-index:200;transform:translateY(100%);transition:transform .3s ease}
  .cp-sticky.visible{transform:translateY(0)}
  .cp-sticky-info{display:flex;align-items:center;gap:10px}
  .cp-sticky-thumb{width:40px;height:40px;background:var(--cp-bg);border-radius:var(--cp-r-sm);border:1px solid var(--cp-border);overflow:hidden}
  .cp-sticky-thumb img{width:100%;height:100%;object-fit:cover}
  .cp-sticky-name{font-size:13px;font-weight:600}
  .cp-sticky-price{font-size:12px;color:var(--cp-muted)}
  .cp-sticky-btn{padding:10px 28px;background:var(--cp-yellow);color:var(--cp-black);border-radius:var(--cp-r-md);font-size:14px;font-weight:700;white-space:nowrap;border:none;cursor:pointer;font-family:var(--cp-font);transition:background .2s}
  .cp-sticky-btn:hover{background:var(--cp-yellow-dk)}

  /* WhatsApp Float */
  .cp-wa{position:fixed;bottom:80px;right:24px;width:50px;height:50px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px;box-shadow:0 4px 16px rgba(37,211,102,.4);z-index:190;transition:transform .2s;text-decoration:none}
  .cp-wa:hover{transform:scale(1.1)}

  /* ─── Responsive ─── */
  @media(max-width:768px){
    /* Core layout — stack vertically, no overflow */
    .cp{overflow-x:hidden}
    .cp-product{
      grid-template-columns:1fr;
      gap:20px;
      padding:16px 16px 48px;
      width:100%;
      max-width:100%;
    }
    .cp-gallery{position:static;width:100%;max-width:100%}
    .cp-info{width:100%;max-width:100%}

    /* Typography */
    .cp-title{font-size:20px}
    .cp-now{font-size:24px}
    .cp-sec-title{font-size:22px}

    /* Trust badges — shrink text on small screens */
    .cp-trust{grid-template-columns:repeat(3,1fr);gap:6px}
    .cp-trust-item{padding:10px 4px}
    .cp-trust-text{font-size:9px}
    .cp-trust-icon{font-size:18px}

    /* Below-fold sections */
    .cp-split,.cp-hiw,.cp-reviews-section,.cp-video-section{
      padding:40px 16px;
      width:100%;
      max-width:100%;
      overflow-x:hidden;
    }
    .cp-split-inner{
      grid-template-columns:1fr;
      gap:20px;
      width:100%;
    }
    /* Fix rtl trick causing overflow on mobile */
    .cp-split.reverse .cp-split-inner{direction:ltr}
    .cp-split.reverse .cp-split-inner > *{direction:ltr}

    /* How it works — single column */
    .cp-steps{grid-template-columns:1fr;gap:16px}

    /* Sticky bar — compact on mobile */
    .cp-sticky{padding:8px 16px;gap:10px}
    .cp-sticky-name{font-size:12px}
    .cp-sticky-price{display:none}
    .cp-sticky-btn{padding:9px 18px;font-size:13px}

    /* WhatsApp float — move up above sticky bar */
    .cp-wa{bottom:70px;right:14px;width:44px;height:44px;font-size:20px}

    /* Accordion */
    .cp-acc-hd{font-size:13px}

    /* Max-width wrapper */
    .cp-mx{padding:0;width:100%;max-width:100%}

    /* Video section */
    .cp-video-wrap{max-width:100%}
  }

  /* Extra small phones */
  @media(max-width:380px){
    .cp-title{font-size:18px}
    .cp-now{font-size:22px}
    .cp-trust{gap:4px}
    .cp-trust-text{font-size:8px}
    .cp-badges{flex-wrap:wrap;gap:6px}
  }
</style>

<div class="cp">

  <!-- ═══ PRODUCT SECTION ═══ -->
  <div class="cp-product cp-mx">

    <!-- Gallery -->
    <div class="cp-gallery">
      <div class="cp-main-img">
        {%- if product.featured_image -%}
          <img id="cpMainImg" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape }}" style="width:100%;height:100%;object-fit:cover" loading="eager" />
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
        {%- if on_sale -%}<span class="cp-sale-tag">{{ discount_pct }}% OFF</span>
        {%- elsif product.available == false -%}<span class="cp-sold-tag">Sold Out</span>{%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="cp-thumbs-wrap">
          <button class="cp-thumb-arrow left" onclick="cpScrollThumbs(-1)" aria-label="Previous">&#8249;</button>
          <div class="cp-thumbs" id="cpThumbTrack">
            {%- for image in product.images -%}
              <div class="cp-thumb {% if forloop.first %}active{% endif %}" onclick="cpSwapImg(this,'{{ image | image_url: width: 800 }}')">
                <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}" width="72" height="72" loading="lazy" />
              </div>
            {%- endfor -%}
          </div>
          <button class="cp-thumb-arrow right" onclick="cpScrollThumbs(1)" aria-label="Next">&#8250;</button>
        </div>
      {%- endif -%}
    </div>

    <!-- Info Panel -->
    <div class="cp-info">
      <div class="cp-badges">
        {%- if on_sale -%}<span class="cp-badge cp-b-yellow">Sale</span>{%- endif -%}
        <span class="cp-badge cp-b-dark">MagSafe</span>
        {%- if product.available -%}<span class="cp-badge cp-b-green">In Stock</span>
        {%- else -%}<span class="cp-badge cp-b-red">Sold Out</span>{%- endif -%}
      </div>

      <h1 class="cp-title">{{ product.title }}</h1>

      <!-- 3 Key Selling Points -->
      <div class="cp-usps">
        <div class="cp-usp"><span class="cp-usp-icon">✓</span> {{ section.settings.usp_1 }}</div>
        <div class="cp-usp"><span class="cp-usp-icon">✓</span> {{ section.settings.usp_2 }}</div>
        <div class="cp-usp"><span class="cp-usp-icon">✓</span> {{ section.settings.usp_3 }}</div>
      </div>

      <div class="cp-rating">
        <span class="cp-stars">★★★★★</span>
        <span class="cp-rating-text">{{ section.settings.review_score }} ({{ section.settings.review_count }} reviews)</span>
        <span class="cp-rating-sold">{{ section.settings.sold_count }} sold</span>
      </div>

      <div class="cp-price">
        <span class="cp-now">{{ current_var.price | money }}</span>
        {%- if on_sale -%}
          <span class="cp-was">{{ current_var.compare_at_price | money }}</span>
          <span class="cp-save">Save {{ discount_pct }}%</span>
        {%- endif -%}
      </div>

      {%- form 'product', product, id: 'cp-product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" id="cp-variant-id" value="{{ current_var.id }}" />

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="cp-variants">
              <div class="cp-var-label">{{ option.name }} <span id="cp-sel-{{ forloop.index }}" style="color:var(--cp-muted);font-weight:400">— {{ option.selected_value }}</span></div>
              <div class="cp-var-opts" data-option-index="{{ forloop.index0 }}">
                {%- for value in option.values -%}
                  <button type="button" class="swatch-btn {% if option.selected_value == value %}active{% endif %}" data-value="{{ value }}" data-option-index="{{ forloop.parentloop.index0 }}" onclick="cpSelectOption(this)">{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <div class="cp-qty-row">
          <span class="cp-qty-label">Quantity</span>
          <div class="cp-qty-ctrl">
            <button type="button" class="cp-qty-btn" onclick="cpChangeQty(-1)">−</button>
            <div class="cp-qty-num" id="cpQtyNum">1</div>
            <button type="button" class="cp-qty-btn" onclick="cpChangeQty(1)">+</button>
          </div>
