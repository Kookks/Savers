      {%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 88 }}" alt="{{ product.title }}" />{%- endif -%}
    </div>
    <div>
      <div class="cp-sticky-name">{{ product.title }}</div>
      <div class="cp-sticky-price">{{ current_var.price | money }}{%- if on_sale -%} <s style="color:#999;font-size:11px">{{ current_var.compare_at_price | money }}</s>{%- endif -%}</div>
    </div>
  </div>
