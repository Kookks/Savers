{% comment %}
  ============================================================
  Savers – Custom Product Page Section
  Compatible with: Dawn 15.x
  Install: Shopify Admin → Online Store → Themes → Edit Code
           → sections/ → Add new file → paste this content
  ============================================================
{% endcomment %}

{%- liquid
  assign product       = section.settings.product | default: product
  assign current_var   = product.selected_or_first_available_variant
  assign compare_price = current_var.compare_at_price
  assign sale_price    = current_var.price
  assign on_sale       = false
  if compare_price > sale_price
    assign on_sale = true
  endif
  assign discount_pct = 0
  if on_sale and compare_price > 0
    assign discount_pct = compare_price | minus: sale_price | times: 100 | divided_by: compare_price
  endif
-%}

<style>
  /* ─── Design Tokens ─── */
  :root {
    --cp-yellow:      #FAE10A;
    --cp-yellow-dark: #D4BC00;
    --cp-black:       #111111;
    --cp-white:       #FFFFFF;
    --cp-bg:          #FAFAFA;
    --cp-text:        #111111;
    --cp-muted:       #666666;
    --cp-light:       #999999;
    --cp-border:      #E8E8E8;
    --cp-green:       #22C55E;
    --cp-danger:      #EF4444;
    --cp-radius-sm:   6px;
    --cp-radius-md:   12px;
    --cp-radius-lg:   20px;
    --cp-radius-pill: 999px;
    --cp-shadow-sm:   0 1px 3px rgba(0,0,0,.08);
    --cp-shadow-md:   0 4px 16px rgba(0,0,0,.10);
    --cp-font:        'Inter', sans-serif;
  }

  .cp-wrap *, .cp-wrap *::before, .cp-wrap *::after { box-sizing: border-box; }
  .cp-wrap { font-family: var(--cp-font); color: var(--cp-text); }

  /* ─── Product Layout ─── */
  .cp-product {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
    padding: 24px 24px 64px;
  }

  /* ─── Gallery ─── */
  .cp-gallery { position: sticky; top: 88px; }
  .cp-gallery-main {
    aspect-ratio: 1/1;
    background: var(--cp-white);
    border-radius: var(--cp-radius-lg);
    border: 1px solid var(--cp-border);
    overflow: hidden;
    position: relative;
    margin-bottom: 12px;
  }
  .cp-gallery-main img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }
  .cp-gallery-main:hover img { transform: scale(1.04); }
  .cp-gallery-sale-badge {
    position: absolute;
    top: 16px; left: 16px;
    background: var(--cp-yellow);
    color: var(--cp-black);
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: var(--cp-radius-pill);
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .cp-gallery-sold-badge {
    position: absolute;
    top: 16px; left: 16px;
    background: #EF4444;
    color: white;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: var(--cp-radius-pill);
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .cp-thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
  }
  .cp-thumb {
    aspect-ratio: 1/1;
    border-radius: var(--cp-radius-sm);
    border: 2px solid var(--cp-border);
    overflow: hidden;
    cursor: pointer;
    transition: border-color .2s;
    background: var(--cp-white);
  }
  .cp-thumb.active { border-color: var(--cp-black); }
  .cp-thumb:hover  { border-color: #aaa; }
  .cp-thumb img    { width: 100%; height: 100%; object-fit: cover; }

  /* ─── Product Info ─── */
  .cp-info { padding-top: 8px; }

  .cp-badge-row { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .cp-badge {
    font-size: 11px; font-weight: 700;
    padding: 4px 10px;
    border-radius: var(--cp-radius-pill);
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .cp-badge-yellow { background: var(--cp-yellow); color: var(--cp-black); }
  .cp-badge-dark   { background: var(--cp-black); color: var(--cp-white); }
  .cp-badge-green  { background: #D1FAE5; color: #065F46; }
  .cp-badge-red    { background: #FEE2E2; color: #991B1B; }

  .cp-title {
    font-size: 30px; font-weight: 800;
    line-height: 1.2; letter-spacing: -.5px;
    margin-bottom: 8px;
  }
  .cp-subtitle { font-size: 15px; color: var(--cp-muted); margin-bottom: 20px; }

  .cp-rating {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 20px;
  }
  .cp-stars { color: #F59E0B; font-size: 15px; }
  .cp-rating-count { font-size: 13px; color: var(--cp-muted); }
  .cp-rating-sold  { font-size: 13px; color: var(--cp-muted); padding-left: 10px; border-left: 1px solid var(--cp-border); }

  .cp-price-row {
    display: flex; align-items: baseline; gap: 12px;
    padding: 16px 0;
    border-top: 1px solid var(--cp-border);
    border-bottom: 1px solid var(--cp-border);
    margin-bottom: 24px;
  }
  .cp-price-current { font-size: 34px; font-weight: 800; }
  .cp-price-orig    { font-size: 18px; color: var(--cp-light); text-decoration: line-through; }
  .cp-price-save    { background: #FEE2E2; color: #991B1B; font-size: 13px; font-weight: 700; padding: 4px 10px; border-radius: var(--cp-radius-pill); }

  /* Variants */
  .cp-variants { margin-bottom: 20px; }
  .cp-variant-label { font-size: 13px; font-weight: 600; margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }
  .cp-variant-options { display: flex; gap: 8px; flex-wrap: wrap; }
  .cp-variant-options .swatch-btn {
    padding: 8px 16px;
    border-radius: var(--cp-radius-sm);
    border: 2px solid var(--cp-border);
    font-size: 13px; font-weight: 500;
    background: var(--cp-white); cursor: pointer;
    transition: all .2s; color: var(--cp-text);
  }
  .cp-variant-options .swatch-btn:hover  { border-color: #aaa; }
  .cp-variant-options .swatch-btn.active { border-color: var(--cp-black); background: var(--cp-black); color: var(--cp-white); }

  /* Qty */
  .cp-qty-row { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }
  .cp-qty-label { font-size: 13px; font-weight: 600; }
  .cp-qty-ctrl {
    display: flex; align-items: center;
    border: 2px solid var(--cp-border);
    border-radius: var(--cp-radius-sm); overflow: hidden;
  }
  .cp-qty-btn {
    width: 40px; height: 40px;
    background: var(--cp-bg); font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .2s; border: none;
    font-family: var(--cp-font);
  }
  .cp-qty-btn:hover { background: var(--cp-border); }
  .cp-qty-num {
    width: 48px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 600;
    border-left: 2px solid var(--cp-border);
    border-right: 2px solid var(--cp-border);
  }

  /* Urgency */
  .cp-urgency {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 16px;
    background: #FFF8DC; border: 1px solid #F0D800;
    border-radius: var(--cp-radius-md); margin-bottom: 20px;
  }
  .cp-pulse {
    width: 10px; height: 10px;
    background: var(--cp-danger); border-radius: 50%;
    animation: cpPulse 1.5s infinite; flex-shrink: 0;
  }
  @keyframes cpPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,.4); }
    50%      { box-shadow: 0 0 0 6px rgba(239,68,68,0); }
  }
  .cp-urgency-text { font-size: 13px; font-weight: 600; color: #92400E; }

  /* CTA Buttons */
  .cp-cta-stack { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
  .cp-btn {
    width: 100%; padding: 16px;
    border-radius: var(--cp-radius-md);
    font-size: 15px; font-weight: 700; letter-spacing: .3px;
    transition: all .2s; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-family: var(--cp-font);
  }
  .cp-btn-primary  { background: var(--cp-yellow); color: var(--cp-black); }
  .cp-btn-primary:hover  { background: var(--cp-yellow-dark); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(250,225,10,.4); }
  .cp-btn-dark     { background: var(--cp-black); color: var(--cp-white); }
  .cp-btn-dark:hover     { background: #333; transform: translateY(-1px); }
  .cp-btn-outline  { background: transparent; color: var(--cp-text); border: 2px solid var(--cp-border); }
  .cp-btn-outline:hover  { border-color: var(--cp-black); }
  .cp-btn[disabled] { opacity: .5; cursor: not-allowed; transform: none; }

  /* Trust Grid */
  .cp-trust {
    display: grid; grid-template-columns: repeat(3,1fr);
    gap: 12px; margin-bottom: 24px;
  }
  .cp-trust-item {
    text-align: center; padding: 14px 8px;
    background: var(--cp-bg); border-radius: var(--cp-radius-md);
    border: 1px solid var(--cp-border);
  }
  .cp-trust-icon { font-size: 22px; margin-bottom: 4px; }
  .cp-trust-text { font-size: 11px; font-weight: 600; line-height: 1.3; color: var(--cp-muted); }

  /* Accordion */
  .cp-accordion { border-top: 1px solid var(--cp-border); margin-top: 32px; }
  .cp-acc-item  { border-bottom: 1px solid var(--cp-border); }
  .cp-acc-header {
    width: 100%; display: flex; justify-content: space-between; align-items: center;
    padding: 16px 0; background: none; font-size: 14px; font-weight: 600;
    color: var(--cp-text); cursor: pointer; text-align: left; border: none;
    font-family: var(--cp-font);
  }
  .cp-acc-icon { font-size: 18px; transition: transform .3s; color: var(--cp-muted); }
  .cp-acc-item.open .cp-acc-icon { transform: rotate(45deg); }
  .cp-acc-body {
    font-size: 14px; color: var(--cp-muted); line-height: 1.7;
    max-height: 0; overflow: hidden;
    transition: max-height .4s ease, padding .3s;
  }
  .cp-acc-item.open .cp-acc-body { max-height: 600px; padding-bottom: 16px; }

  /* ─── Features ─── */
  .cp-features {
    background: var(--cp-black); color: var(--cp-white);
    padding: 80px 24px;
  }
  .cp-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--cp-yellow); margin-bottom: 12px; }
  .cp-section-title { font-size: 38px; font-weight: 800; line-height: 1.15; letter-spacing: -.5px; margin-bottom: 16px; }
  .cp-section-sub { font-size: 16px; color: rgba(255,255,255,.55); max-width: 540px; margin-bottom: 56px; }
  .cp-feat-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 24px; }
  .cp-feat-card {
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
    border-radius: var(--cp-radius-lg); padding: 28px 24px;
    transition: background .3s, transform .3s;
  }
  .cp-feat-card:hover { background: rgba(250,225,10,.08); transform: translateY(-4px); border-color: rgba(250,225,10,.25); }
  .cp-feat-icon { width: 48px; height: 48px; background: var(--cp-yellow); border-radius: var(--cp-radius-md); display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 16px; }
  .cp-feat-title { font-size: 15px; font-weight: 700; margin-bottom: 8px; color: var(--cp-white); }
  .cp-feat-desc  { font-size: 13px; color: rgba(255,255,255,.5); line-height: 1.6; }

  /* ─── How It Works ─── */
  .cp-hiw { background: var(--cp-bg); padding: 80px 24px; }
  .cp-hiw-header { text-align: center; margin-bottom: 56px; }
  .cp-hiw-title { color: var(--cp-text); }
  .cp-steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 32px; position: relative; }
  .cp-steps::before {
    content: ''; position: absolute; top: 28px;
    left: calc(16.6% + 28px); right: calc(16.6% + 28px);
    height: 2px; background: linear-gradient(90deg, var(--cp-border), var(--cp-yellow), var(--cp-border));
  }
  .cp-step { text-align: center; }
  .cp-step-num {
    width: 56px; height: 56px; background: var(--cp-yellow); color: var(--cp-black);
    border-radius: 50%; font-size: 20px; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px; border: 4px solid var(--cp-bg);
    box-shadow: var(--cp-shadow-md); position: relative; z-index: 1;
  }
  .cp-step-title { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
  .cp-step-desc  { font-size: 13px; color: var(--cp-muted); line-height: 1.6; }

  /* ─── Reviews ─── */
  .cp-reviews { background: var(--cp-white); padding: 80px 24px; }
  .cp-reviews-header { text-align: center; margin-bottom: 48px; }
  .cp-overall { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 16px; }
  .cp-big-score { font-size: 56px; font-weight: 800; line-height: 1; }
  .cp-score-stars { color: #F59E0B; font-size: 20px; }
  .cp-score-count { font-size: 13px; color: var(--cp-muted); margin-top: 4px; }
  .cp-reviews-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
  .cp-review-card {
    background: var(--cp-bg); border: 1px solid var(--cp-border);
    border-radius: var(--cp-radius-lg); padding: 24px;
    transition: box-shadow .3s, transform .3s;
  }
  .cp-review-card:hover { box-shadow: var(--cp-shadow-md); transform: translateY(-2px); }
  .cp-review-stars { color: #F59E0B; font-size: 14px; margin-bottom: 12px; }
  .cp-review-text { font-size: 14px; line-height: 1.6; margin-bottom: 16px; font-style: italic; }
  .cp-review-meta { display: flex; align-items: center; gap: 10px; }
  .cp-review-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--cp-yellow); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; color: var(--cp-black); flex-shrink: 0; }
  .cp-review-name { font-size: 13px; font-weight: 600; }
  .cp-review-date { font-size: 11px; color: var(--cp-light); }
  .cp-verified { font-size: 11px; color: var(--cp-green); font-weight: 600; }

  /* ─── Sticky Bar ─── */
  .cp-sticky {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--cp-white); border-top: 1px solid var(--cp-border);
    padding: 12px 24px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    box-shadow: 0 -4px 20px rgba(0,0,0,.1); z-index: 200;
    transform: translateY(100%); transition: transform .3s ease;
  }
  .cp-sticky.visible { transform: translateY(0); }
  .cp-sticky-product { display: flex; align-items: center; gap: 12px; }
  .cp-sticky-thumb { width: 44px; height: 44px; background: var(--cp-bg); border-radius: var(--cp-radius-sm); border: 1px solid var(--cp-border); overflow: hidden; }
  .cp-sticky-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .cp-sticky-name  { font-size: 13px; font-weight: 600; }
  .cp-sticky-price { font-size: 12px; color: var(--cp-muted); }
  .cp-sticky-cta {
    padding: 12px 32px; background: var(--cp-yellow); color: var(--cp-black);
    border-radius: var(--cp-radius-md); font-size: 14px; font-weight: 700;
    white-space: nowrap; transition: background .2s; border: none; cursor: pointer;
    font-family: var(--cp-font);
  }
  .cp-sticky-cta:hover { background: var(--cp-yellow-dark); }

  /* WhatsApp */
  .cp-whatsapp {
    position: fixed; bottom: 88px; right: 24px;
    width: 52px; height: 52px; background: #25D366;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 26px; box-shadow: 0 4px 16px rgba(37,211,102,.4); z-index: 190;
    transition: transform .2s, box-shadow .2s; text-decoration: none;
  }
  .cp-whatsapp:hover { transform: scale(1.1); box-shadow: 0 6px 24px rgba(37,211,102,.5); }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .cp-product { grid-template-columns: 1fr; gap: 32px; padding: 16px 16px 48px; }
    .cp-gallery { position: static; }
    .cp-title { font-size: 24px; }
    .cp-price-current { font-size: 28px; }
    .cp-section-title { font-size: 28px; }
    .cp-feat-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
    .cp-steps { grid-template-columns: 1fr; }
    .cp-steps::before { display: none; }
    .cp-reviews-grid { grid-template-columns: 1fr; }
    .cp-hiw, .cp-features, .cp-reviews { padding: 56px 16px; }
  }
  @media (max-width: 480px) {
    .cp-feat-grid { grid-template-columns: 1fr; }
    .cp-thumbs { grid-template-columns: repeat(4,1fr); }
  }
</style>

<div class="cp-wrap">

  <!-- Product Section -->
  <div class="cp-product">

    <!-- Gallery -->
    <div class="cp-gallery">
      <div class="cp-gallery-main" id="cp-main-img-wrap">
        {%- if product.featured_image -%}
          <img id="cpMainImg"
               src="{{ product.featured_image | image_url: width: 800 }}"
               alt="{{ product.featured_image.alt | escape }}"
               width="800" height="800" loading="eager" />
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'cp-placeholder-img' }}
        {%- endif -%}

        {%- if on_sale -%}
          <span class="cp-gallery-sale-badge">{{ discount_pct }}% OFF</span>
        {%- elsif product.available == false -%}
          <span class="cp-gallery-sold-badge">Sold Out</span>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="cp-thumbs">
          {%- for image in product.images limit: 5 -%}
            <div class="cp-thumb {% if forloop.first %}active{% endif %}"
                 onclick="cpSwapImg(this, '{{ image | image_url: width: 800 }}')">
              <img src="{{ image | image_url: width: 150 }}"
                   alt="{{ image.alt | escape }}"
                   width="150" height="150" loading="lazy" />
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info Panel -->
    <div class="cp-info">

      <!-- Badges -->
      <div class="cp-badge-row">
        {%- if on_sale -%}
          <span class="cp-badge cp-badge-yellow">Sale</span>
        {%- endif -%}
        <span class="cp-badge cp-badge-dark">MagSafe</span>
        {%- if product.available -%}
          <span class="cp-badge cp-badge-green">In Stock</span>
        {%- else -%}
          <span class="cp-badge cp-badge-red">Sold Out</span>
        {%- endif -%}
      </div>

      <h1 class="cp-title">{{ product.title }}</h1>
      {%- if product.metafields.custom.subtitle -%}
        <p class="cp-subtitle">{{ product.metafields.custom.subtitle }}</p>
      {%- else -%}
        <p class="cp-subtitle">Pro-grade polarizing filter with 1-second MagSafe attachment.</p>
      {%- endif -%}

      <!-- Ratings (numbers controlled via Theme Customizer → Section Settings) -->
      <div class="cp-rating">
        <span class="cp-stars">★★★★★</span>
        <span class="cp-rating-count">{{ section.settings.review_score }} ({{ section.settings.review_count }} reviews)</span>
        <span class="cp-rating-sold">{{ section.settings.sold_count }} sold this month</span>
      </div>

      <!-- Price -->
      <div class="cp-price-row" id="cp-price-row">
        <span class="cp-price-current">{{ current_var.price | money }}</span>
        {%- if on_sale -%}
          <span class="cp-price-orig">{{ current_var.compare_at_price | money }}</span>
          <span class="cp-price-save">Save {{ discount_pct }}%</span>
        {%- endif -%}
      </div>

      <!-- Shopify Product Form -->
      {%- form 'product', product, id: 'cp-product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" id="cp-variant-id" value="{{ current_var.id }}" />

        <!-- Variant Options -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="cp-variants">
              <div class="cp-variant-label">
                {{ option.name }}
                <span id="cp-sel-{{ forloop.index }}" style="color:var(--cp-muted);font-weight:400">
                  — {{ option.selected_value }}
                </span>
              </div>
              <div class="cp-variant-options" data-option-index="{{ forloop.index0 }}">
                {%- for value in option.values -%}
                  <button type="button"
                          class="swatch-btn {% if option.selected_value == value %}active{% endif %}"
                          data-value="{{ value }}"
                          data-option-index="{{ forloop.parentloop.index0 }}"
                          onclick="cpSelectOption(this)">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- Quantity -->
        <div class="cp-qty-row">
          <span class="cp-qty-label">Quantity</span>
          <div class="cp-qty-ctrl">
            <button type="button" class="cp-qty-btn" onclick="cpChangeQty(-1)">−</button>
            <div class="cp-qty-num" id="cpQtyNum">1</div>
            <button type="button" class="cp-qty-btn" onclick="cpChangeQty(1)">+</button>
          </div>
          <input type="hidden" name="quantity" id="cpQtyInput" value="1" />
        </div>

        <!-- Urgency Bar -->
        <div class="cp-urgency">
          <div class="cp-pulse"></div>
          <span class="cp-urgency-text">⚡ Only {{ section.settings.units_left }} units left — hurry before it sells out!</span>
        </div>

        <!-- CTA Buttons -->
        <div class="cp-cta-stack" id="cp-cta-area">
          {%- if product.available -%}
            <button type="submit" name="add" id="cpAddToCart" class="cp-btn cp-btn-primary">
              🛒 Add to Cart
            </button>
            <button type="button" id="cpBuyNow" class="cp-btn cp-btn-dark" onclick="cpBuyNow()">
              ⚡ Buy Now
            </button>
          {%- else -%}
            <button type="button" class="cp-btn cp-btn-primary" disabled>
              Sold Out
            </button>
          {%- endif -%}
