        </div>
      </div>
    </div>
  </div>

  <!-- ═══ VIDEO SECTION ═══ -->
  <div class="cp-video-section">
    <div class="cp-video-wrap">
      <p class="cp-eyebrow" style="color:var(--cp-yellow)">See It In Action</p>
      <h2 class="cp-sec-title" style="color:#fff">Watch the difference in real time</h2>
      <div class="cp-video-container">
        {% comment %}
          REPLACE: Embed your video here. Options:
          1. Upload to Shopify (Settings > Files) and use <video src="URL" controls></video>
          2. Or paste a YouTube embed: <iframe src="https://www.youtube.com/embed/YOUR_ID" frameborder="0" allowfullscreen></iframe>
