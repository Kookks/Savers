        <div class="cp-trust-item"><div class="cp-trust-icon">🔄</div><div class="cp-trust-text">30-Day<br>Returns</div></div>
        <div class="cp-trust-item"><div class="cp-trust-icon">💵</div><div class="cp-trust-text">Cash on<br>Delivery</div></div>
