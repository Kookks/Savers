</div>

<!-- WhatsApp Float (for support chat, not ordering) -->
<a href="https://wa.me/{{ section.settings.whatsapp_number }}" class="cp-wa" target="_blank" title="Chat on WhatsApp">💬</a>

<script type="application/json" id="cpVariantsData">{{ product.variants | json }}</script>

<script>
(function(){
  /* Gallery */
  window.cpSwapImg=function(t,src){
    document.querySelectorAll('.cp-thumb').forEach(function(el){el.classList.remove('active')});
    t.classList.add('active');
    document.getElementById('cpMainImg').src=src;
  };
  /* Thumbnail carousel scroll */
  window.cpScrollThumbs=function(dir){
    var track=document.getElementById('cpThumbTrack');
    if(track) track.scrollBy({left:dir*160,behavior:'smooth'});
  };
  /* Quantity */
  var qty=1;
  window.cpChangeQty=function(d){
    qty=Math.max(1,qty+d);
    document.getElementById('cpQtyNum').textContent=qty;
    document.getElementById('cpQtyInput').value=qty;
  };
  /* Accordion */
  window.cpToggleAcc=function(b){b.closest('.cp-acc-item').classList.toggle('open')};
  /* Variants */
  var vars=JSON.parse(document.getElementById('cpVariantsData').textContent);
  var sel={};
  document.querySelectorAll('.cp-var-opts').forEach(function(g){
    var a=g.querySelector('.swatch-btn.active');
    if(a) sel[g.dataset.optionIndex]=a.dataset.value;
  });
  window.cpSelectOption=function(btn){
    var i=btn.dataset.optionIndex;
    btn.closest('.cp-var-opts').querySelectorAll('.swatch-btn').forEach(function(b){b.classList.remove('active')});
    btn.classList.add('active');
    sel[i]=btn.dataset.value;
    var lbl=document.getElementById('cp-sel-'+(parseInt(i)+1));
    if(lbl) lbl.textContent='— '+btn.dataset.value;
    var m=vars.find(function(v){return v.options.every(function(o,idx){return sel[String(idx)]===o})});
    if(m){
      document.getElementById('cp-variant-id').value=m.id;
      var p=document.querySelector('.cp-now');if(p)p.textContent='$'+(m.price/100).toFixed(2);
      var b=document.getElementById('cpAddToCart');
      if(b){b.disabled=!m.available;b.textContent=m.available?'Add to Cart — $'+(m.price/100).toFixed(2):'Sold Out'}
    }
  };
  /* Sticky bar */
  var sb=document.getElementById('cpStickyBar'),ca=document.getElementById('cp-cta-area');
  if(sb&&ca){window.addEventListener('scroll',function(){
    sb.classList.toggle('visible',ca.getBoundingClientRect().bottom<0);
  })}
})();
</script>

{% schema %}
{
  "name": "Custom Product Page",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "WhatsApp"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp Number (with country code, no +)",
      "default": "96170000000"
    },
    {
      "type": "header",
      "content": "Key Selling Points (under title)"
    },
    {
      "type": "text",
      "id": "usp_1",
      "label": "Selling Point 1",
      "default": "Snaps on magnetically in 1 second — no adapters needed"
    },
    {
      "type": "text",
      "id": "usp_2",
      "label": "Selling Point 2",
      "default": "Eliminates glare and boosts colours instantly"
    },
    {
      "type": "text",
      "id": "usp_3",
      "label": "Selling Point 3",
      "default": "Fits all iPhones 12–16 with any MagSafe case"
    },
    {
      "type": "header",
      "content": "Social Proof"
    },
    {
      "type": "text",
      "id": "review_score",
      "label": "Review Score",
      "default": "4.9"
    },
    {
      "type": "number",
      "id": "review_count",
      "label": "Number of Reviews",
      "default": 127
    },
    {
      "type": "text",
      "id": "sold_count",
      "label": "Units Sold (e.g. 500+)",
      "default": "500+"
    },
    {
      "type": "number",
      "id": "units_left",
      "label": "Units Left (urgency bar)",
      "default": 7
    }
  ],
  "presets": [
    {
      "name": "Custom Product Page"
    }
  ]
}
{% endschema %}