<script>
(function() {

  /* ─── Gallery ─── */
  window.cpSwapImg = function(thumb, src) {
    document.querySelectorAll('.cp-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
    document.getElementById('cpMainImg').src = src;
  };

  /* ─── Quantity ─── */
  var cpQty = 1;
  window.cpChangeQty = function(delta) {
    cpQty = Math.max(1, cpQty + delta);
    document.getElementById('cpQtyNum').textContent  = cpQty;
    document.getElementById('cpQtyInput').value = cpQty;
  };

  /* ─── Buy Now (native form POST → /cart/add → /checkout) ─── */
  window.cpBuyNow = function() {
    document.getElementById('cp-buynow-id').value  = document.getElementById('cp-variant-id').value;
    document.getElementById('cp-buynow-qty').value = document.getElementById('cpQtyInput').value || 1;
    document.getElementById('cp-buynow-form').submit();
  };

  /* ─── Accordion ─── */
  window.cpToggleAcc = function(btn) {
    btn.closest('.cp-acc-item').classList.toggle('open');
  };

  /* ─── Variant Selection ─── */
  var cpVariants   = JSON.parse(document.getElementById('cpVariantsData').textContent);
  var cpSelections = {};

  // initialise selections from active buttons
  document.querySelectorAll('.cp-variant-options').forEach(function(group) {
    var active = group.querySelector('.swatch-btn.active');
    if (active) cpSelections[group.dataset.optionIndex] = active.dataset.value;
  });

  window.cpSelectOption = function(btn) {
    var idx = btn.dataset.optionIndex;
    btn.closest('.cp-variant-options').querySelectorAll('.swatch-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    cpSelections[idx] = btn.dataset.value;

    // Update displayed label
    var label = document.getElementById('cp-sel-' + (parseInt(idx)+1));
    if (label) label.textContent = '— ' + btn.dataset.value;

    // Find matching variant
    var match = cpVariants.find(function(v) {
      return v.options.every(function(opt, i) {
        return cpSelections[String(i)] === opt || cpSelections[i] === opt;
      });
    });

    if (match) {
      document.getElementById('cp-variant-id').value = match.id;

      // Update price
      var priceEl = document.querySelector('.cp-price-current');
      if (priceEl) {
        priceEl.textContent = formatMoney(match.price);
      }

      // Toggle availability
      var atcBtn = document.getElementById('cpAddToCart');
      if (atcBtn) {
        atcBtn.disabled  = !match.available;
        atcBtn.textContent = match.available ? '🛒 Add to Cart' : 'Sold Out';
      }
    }
  };

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  /* ─── Sticky Bar ─── */
  var stickyBar = document.getElementById('cpStickyBar');
  var ctaArea   = document.getElementById('cp-cta-area');
  if (stickyBar && ctaArea) {
    window.addEventListener('scroll', function() {
      var bottom = ctaArea.getBoundingClientRect().bottom;
      if (bottom < 0) { stickyBar.classList.add('visible'); }
      else             { stickyBar.classList.remove('visible'); }
    });
  }

})();
</script>

