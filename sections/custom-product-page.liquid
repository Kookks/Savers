  <!-- ═══ HOW IT WORKS (with image cards) ═══ -->
  <div class="cp-hiw">
    <div class="cp-mx">
      <div class="cp-hiw-header">
        <p class="cp-eyebrow">Setup In 3 Seconds</p>
        <h2 class="cp-sec-title">Attach. Rotate. Shoot.</h2>
