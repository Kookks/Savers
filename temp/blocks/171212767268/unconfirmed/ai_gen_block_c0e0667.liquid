{% doc %}
  @prompt
    Embedded youtube video with autoplau and the title is How does it work
    here is the yt link https://github.com/Nohra2005/locus.git, make the video vertical
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-youtube-video-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-youtube-video__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-youtube-video__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-youtube-video__wrapper-{{ ai_gen_id }} {
    position: relative;
    padding-bottom: 177.78%;
    height: 0;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
    max-width: 500px;
    margin: 0 auto;
  }

  .ai-youtube-video__iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .ai-youtube-video__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 16px;
  }

  .ai-youtube-video__placeholder-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-youtube-video__placeholder-text-{{ ai_gen_id }} {
    color: #666;
    font-size: 14px;
    text-align: center;
    padding: 0 20px;
  }
{% endstyle %}

<div class="ai-youtube-video-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-youtube-video__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-youtube-video__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <div class="ai-youtube-video__wrapper-{{ ai_gen_id }}">
      {% if block.settings.youtube_url != blank %}
        {% assign video_id = '' %}
        {% if block.settings.youtube_url contains 'youtube.com/watch?v=' %}
          {% assign video_id = block.settings.youtube_url | split: 'watch?v=' | last | split: '&' | first %}
        {% elsif block.settings.youtube_url contains 'youtu.be/' %}
          {% assign video_id = block.settings.youtube_url | split: 'youtu.be/' | last | split: '?' | first %}
        {% elsif block.settings.youtube_url contains 'youtube.com/embed/' %}
          {% assign video_id = block.settings.youtube_url | split: 'embed/' | last | split: '?' | first %}
        {% endif %}

        {% if video_id != blank %}
          {% assign autoplay_param = '' %}
          {% if block.settings.autoplay %}
            {% assign autoplay_param = '&autoplay=1&mute=1' %}
          {% endif %}

          {% assign loop_param = '' %}
          {% if block.settings.loop %}
            {% assign loop_param = '&loop=1&playlist=' | append: video_id %}
          {% endif %}

          <iframe
            class="ai-youtube-video__iframe-{{ ai_gen_id }}"
            src="https://www.youtube.com/embed/{{ video_id }}?rel=0{{ autoplay_param }}{{ loop_param }}"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        {% else %}
          <div class="ai-youtube-video__placeholder-{{ ai_gen_id }}">
            <svg class="ai-youtube-video__placeholder-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            <div class="ai-youtube-video__placeholder-text-{{ ai_gen_id }}">
              Invalid YouTube URL. Please enter a valid link.
            </div>
          </div>
        {% endif %}
      {% else %}
        <div class="ai-youtube-video__placeholder-{{ ai_gen_id }}">
          <svg class="ai-youtube-video__placeholder-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <div class="ai-youtube-video__placeholder-text-{{ ai_gen_id }}">
            Next, add your YouTube video URL
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "YouTube video",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "YouTube URL",
      "info": "Paste your YouTube video link (e.g., https://www.youtube.com/watch?v=VIDEO_ID)"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": true,
      "info": "Video will be muted when autoplay is enabled"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "How does it work"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Spacing below title",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Container border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Video border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "YouTube video"
    }
  ]
}
{% endschema %}
