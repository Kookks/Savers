{% doc %}
  @prompt
    embedded yt video please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-youtube-embed-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-youtube-embed__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #000000;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-youtube-embed__iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-youtube-embed__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-youtube-embed__placeholder-content-{{ ai_gen_id }} {
    text-align: center;
    padding: 20px;
  }

  .ai-youtube-embed__placeholder-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 16px;
    opacity: 0.3;
  }

  .ai-youtube-embed__placeholder-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666;
  }

  @media screen and (max-width: 749px) {
    .ai-youtube-embed-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-youtube-embed-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-youtube-embed__wrapper-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      {% assign video_id = '' %}
      {% if block.settings.video_url contains 'youtube.com/watch?v=' %}
        {% assign video_id = block.settings.video_url | split: 'v=' | last | split: '&' | first %}
      {% elsif block.settings.video_url contains 'youtu.be/' %}
        {% assign video_id = block.settings.video_url | split: 'youtu.be/' | last | split: '?' | first %}
      {% elsif block.settings.video_url contains 'youtube.com/embed/' %}
        {% assign video_id = block.settings.video_url | split: 'embed/' | last | split: '?' | first %}
      {% endif %}

      {% if video_id != blank %}
        <iframe
          class="ai-youtube-embed__iframe-{{ ai_gen_id }}"
          src="https://www.youtube.com/embed/{{ video_id }}?rel=0{% if block.settings.autoplay %}&autoplay=1&mute=1{% endif %}{% if block.settings.loop %}&loop=1&playlist={{ video_id }}{% endif %}{% if block.settings.controls == false %}&controls=0{% endif %}{% if block.settings.show_info == false %}&showinfo=0{% endif %}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
          title="{{ block.settings.video_title | escape }}"
        ></iframe>
      {% else %}
        <div class="ai-youtube-embed__placeholder-{{ ai_gen_id }}">
          <div class="ai-youtube-embed__placeholder-content-{{ ai_gen_id }}">
            <svg class="ai-youtube-embed__placeholder-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            <div class="ai-youtube-embed__placeholder-text-{{ ai_gen_id }}">
              Invalid YouTube URL
            </div>
          </div>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-youtube-embed__placeholder-{{ ai_gen_id }}">
        <div class="ai-youtube-embed__placeholder-content-{{ ai_gen_id }}">
          <svg class="ai-youtube-embed__placeholder-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <div class="ai-youtube-embed__placeholder-text-{{ ai_gen_id }}">
            Add a YouTube video URL
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "YouTube video",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "YouTube URL",
      "placeholder": "https://www.youtube.com/watch?v=..."
    },
    {
      "type": "text",
      "id": "video_title",
      "label": "Video title",
      "default": "YouTube video"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Playback"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_info",
      "label": "Show video info",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "YouTube video"
    }
  ]
}
{% endschema %}
