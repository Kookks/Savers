{% doc %}
  @prompt
    Add a static star rating display showing 4.9 stars out of 5 with 7 reviews, positioned directly under the product title on the product page. It should show filled/partial star icons visually representing 4.9 stars, the number "4.9" and "(7 reviews)" text next to it. Style it to look clean and professional, matching the store's theme.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-star-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-star-rating__stars-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .ai-star-rating__star-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    display: inline-block;
  }

  .ai-star-rating__star-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    color: {{ block.settings.empty_star_color }};
  }

  .ai-star-rating__star-fill-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    overflow: hidden;
    color: {{ block.settings.filled_star_color }};
  }

  .ai-star-rating__star-bg-{{ ai_gen_id }} svg,
  .ai-star-rating__star-fill-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ai-star-rating__text-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-star-rating__number-{{ ai_gen_id }} {
    font-weight: 600;
  }

  .ai-star-rating__reviews-{{ ai_gen_id }} {
    color: {{ block.settings.reviews_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-star-rating__star-{{ ai_gen_id }} {
      width: {{ block.settings.star_size | times: 0.9 }}px;
      height: {{ block.settings.star_size | times: 0.9 }}px;
    }

    .ai-star-rating__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-star-rating-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-star-rating__stars-{{ ai_gen_id }}">
    {% assign rating = block.settings.rating %}
    {% assign full_stars = rating | floor %}
    {% assign decimal_part = rating | modulo: 1 %}
    {% assign partial_width = decimal_part | times: 100 %}
    {% assign next_star = full_stars | plus: 1 %}

    {% for i in (1..5) %}
      <span class="ai-star-rating__star-{{ ai_gen_id }}">
        <span class="ai-star-rating__star-bg-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </span>
        {% if i <= full_stars %}
          <span class="ai-star-rating__star-fill-{{ ai_gen_id }}" style="width: 100%;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </span>
        {% elsif i == next_star and decimal_part > 0 %}
          <span class="ai-star-rating__star-fill-{{ ai_gen_id }}" style="width: {{ partial_width }}%;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </span>
        {% endif %}
      </span>
    {% endfor %}
  </div>

  <div class="ai-star-rating__text-{{ ai_gen_id }}">
    <span class="ai-star-rating__number-{{ ai_gen_id }}">{{ block.settings.rating }}</span>
    <span class="ai-star-rating__reviews-{{ ai_gen_id }}">({{ block.settings.review_count }} reviews)</span>
  </div>
</div>

{% schema %}
{
  "name": "Static star rating",
  "settings": [
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "range",
      "id": "rating",
      "label": "Star rating",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "default": 4.9
    },
    {
      "type": "range",
      "id": "review_count",
      "label": "Number of reviews",
      "min": 0,
      "max": 500,
      "step": 5,
      "default": 5
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "filled_star_color",
      "label": "Filled star color",
      "default": "#fae10a"
    },
    {
      "type": "color",
      "id": "empty_star_color",
      "label": "Empty star color",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Rating number color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "reviews_text_color",
      "label": "Reviews text color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Static star rating"
    }
  ]
}
{% endschema %}
