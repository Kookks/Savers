{% doc %}
  @prompt
    generate a comparaison between "WITHOUT FILTER" and "WITH THIS FILTER"
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-filter-comparison-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-filter-comparison__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-filter-comparison__images-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 75%;
    overflow: hidden;
  }

  .ai-filter-comparison__image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-filter-comparison__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-filter-comparison__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-filter-comparison__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-filter-comparison__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-filter-comparison__image-wrapper-{{ ai_gen_id }}--after {
    clip-path: inset(0 0 0 50%);
    transition: clip-path 0.3s ease;
  }

  .ai-filter-comparison__slider-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 50%;
    width: 4px;
    height: 100%;
    background-color: {{ block.settings.slider_color }};
    cursor: ew-resize;
    transform: translateX(-50%);
    z-index: 10;
  }

  .ai-filter-comparison__slider-handle-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.handle_size }}px;
    height: {{ block.settings.handle_size }}px;
    background-color: {{ block.settings.slider_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .ai-filter-comparison__slider-handle-{{ ai_gen_id }}::before,
  .ai-filter-comparison__slider-handle-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
  }

  .ai-filter-comparison__slider-handle-{{ ai_gen_id }}::before {
    left: 25%;
    border-width: 6px 8px 6px 0;
    border-color: transparent {{ block.settings.handle_arrow_color }} transparent transparent;
  }

  .ai-filter-comparison__slider-handle-{{ ai_gen_id }}::after {
    right: 25%;
    border-width: 6px 0 6px 8px;
    border-color: transparent transparent transparent {{ block.settings.handle_arrow_color }};
  }

  .ai-filter-comparison__labels-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 5;
  }

  .ai-filter-comparison__label-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.label_position_vertical }}%;
    padding: {{ block.settings.label_padding }}px {{ block.settings.label_padding | times: 1.5 }}px;
    background-color: {{ block.settings.label_background }};
    color: {{ block.settings.label_text_color }};
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: {{ block.settings.label_font_weight }};
    border-radius: {{ block.settings.label_border_radius }}px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-filter-comparison__label-{{ ai_gen_id }}--before {
    left: {{ block.settings.label_position_horizontal }}%;
    transform: translateY(-50%);
  }

  .ai-filter-comparison__label-{{ ai_gen_id }}--after {
    right: {{ block.settings.label_position_horizontal }}%;
    transform: translateY(-50%);
  }

  @media screen and (max-width: 749px) {
    .ai-filter-comparison__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_font_size | times: 0.85 }}px;
      padding: {{ block.settings.label_padding | times: 0.8 }}px {{ block.settings.label_padding | times: 1.2 }}px;
    }

    .ai-filter-comparison__slider-handle-{{ ai_gen_id }} {
      width: {{ block.settings.handle_size | times: 0.8 }}px;
      height: {{ block.settings.handle_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<filter-comparison-{{ ai_gen_id }}
  class="ai-filter-comparison-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-filter-comparison__container-{{ ai_gen_id }}">
    <div class="ai-filter-comparison__images-{{ ai_gen_id }}">
      <div class="ai-filter-comparison__image-wrapper-{{ ai_gen_id }} ai-filter-comparison__image-wrapper-{{ ai_gen_id }}--before">
        {% if block.settings.image_without_filter %}
          <img
            src="{{ block.settings.image_without_filter | image_url: width: 1200 }}"
            alt="{{ block.settings.label_without_filter | escape }}"
            loading="lazy"
            width="{{ block.settings.image_without_filter.width }}"
            height="{{ block.settings.image_without_filter.height }}"
            class="ai-filter-comparison__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-filter-comparison__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-filter-comparison__empty-state-{{ ai_gen_id }}">
              Add "Without filter" image
            </div>
          </div>
        {% endif %}
      </div>

      <div
        class="ai-filter-comparison__image-wrapper-{{ ai_gen_id }} ai-filter-comparison__image-wrapper-{{ ai_gen_id }}--after"
        data-after-image
      >
        {% if block.settings.image_with_filter %}
          <img
            src="{{ block.settings.image_with_filter | image_url: width: 1200 }}"
            alt="{{ block.settings.label_with_filter | escape }}"
            loading="lazy"
            width="{{ block.settings.image_with_filter.width }}"
            height="{{ block.settings.image_with_filter.height }}"
            class="ai-filter-comparison__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-filter-comparison__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-filter-comparison__empty-state-{{ ai_gen_id }}">
              Add "With filter" image
            </div>
          </div>
        {% endif %}
      </div>

      {% if block.settings.show_labels %}
        <div class="ai-filter-comparison__labels-{{ ai_gen_id }}">
          <div class="ai-filter-comparison__label-{{ ai_gen_id }} ai-filter-comparison__label-{{ ai_gen_id }}--before">
            {{ block.settings.label_without_filter }}
          </div>
          <div class="ai-filter-comparison__label-{{ ai_gen_id }} ai-filter-comparison__label-{{ ai_gen_id }}--after">
            {{ block.settings.label_with_filter }}
          </div>
        </div>
      {% endif %}

      <div class="ai-filter-comparison__slider-{{ ai_gen_id }}" data-slider>
        <div class="ai-filter-comparison__slider-handle-{{ ai_gen_id }}"></div>
      </div>
    </div>
  </div>
</filter-comparison-{{ ai_gen_id }}>

<script>
  (function() {
    class FilterComparison{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.isDragging = false;
      }

      connectedCallback() {
        this.slider = this.querySelector('[data-slider]');
        this.afterImage = this.querySelector('[data-after-image]');
        this.container = this.querySelector('.ai-filter-comparison__images-{{ ai_gen_id }}');

        if (!this.slider || !this.afterImage || !this.container) return;

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.slider.addEventListener('mousedown', this.startDrag.bind(this));
        this.slider.addEventListener('touchstart', this.startDrag.bind(this), { passive: true });

        document.addEventListener('mousemove', this.onDrag.bind(this));
        document.addEventListener('touchmove', this.onDrag.bind(this), { passive: false });

        document.addEventListener('mouseup', this.stopDrag.bind(this));
        document.addEventListener('touchend', this.stopDrag.bind(this));

        this.container.addEventListener('click', this.onContainerClick.bind(this));
      }

      startDrag(e) {
        this.isDragging = true;
        e.preventDefault();
      }

      stopDrag() {
        this.isDragging = false;
      }

      onDrag(e) {
        if (!this.isDragging) return;

        e.preventDefault();
        this.updateSliderPosition(e);
      }

      onContainerClick(e) {
        if (e.target.closest('[data-slider]')) return;
        this.updateSliderPosition(e);
      }

      updateSliderPosition(e) {
        const rect = this.container.getBoundingClientRect();
        const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        const x = clientX - rect.left;
        const percentage = Math.max(0, Math.min(100, (x / rect.width) * 100));

        this.slider.style.left = percentage + '%';
        this.afterImage.style.clipPath = `inset(0 0 0 ${percentage}%)`;
      }
    }

    customElements.define('filter-comparison-{{ ai_gen_id }}', FilterComparison{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Filter comparison",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_without_filter",
      "label": "Without filter image"
    },
    {
      "type": "image_picker",
      "id": "image_with_filter",
      "label": "With filter image"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f4f4f4"
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "checkbox",
      "id": "show_labels",
      "label": "Show labels",
      "default": true
    },
    {
      "type": "text",
      "id": "label_without_filter",
      "label": "Without filter label",
      "default": "Without filter"
    },
    {
      "type": "text",
      "id": "label_with_filter",
      "label": "With filter label",
      "default": "With this filter"
    },
    {
      "type": "range",
      "id": "label_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "label_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "label_padding",
      "label": "Padding",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "label_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "label_background",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "label_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "label_position_vertical",
      "label": "Vertical position",
      "min": 5,
      "max": 95,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "label_position_horizontal",
      "label": "Horizontal position",
      "min": 5,
      "max": 45,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "color",
      "id": "slider_color",
      "label": "Slider color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "handle_size",
      "label": "Handle size",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "handle_arrow_color",
      "label": "Handle arrow color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Filter comparison"
    }
  ]
}
{% endschema %}
