{% doc %}
  @prompt
    Generate a block that says:
    
    📱 Works With Your iPhone
    iPhone 16 Pro Max
    iPhone 16 Pro
    iPhone 16 Plus
    iPhone 16
    iPhone 15 Pro Max
    iPhone 15 Pro
    iPhone 15 Plus
    iPhone 15
    iPhone 14 Pro Max
    iPhone 14 Pro
    iPhone 14 Plus
    iPhone 14
    iPhone 13 Series
    iPhone 12 Series
    All MagSafe Cases ✓
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-iphone-compat-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-iphone-compat__header-{{ ai_gen_id }} {
    font-size: {{ block.settings.header_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
  }

  .ai-iphone-compat__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-iphone-compat__item-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-iphone-compat__footer-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_size }}px;
    color: {{ block.settings.text_color }};
    margin-top: {{ block.settings.spacing }}px;
    font-weight: 500;
  }
{% endstyle %}

<div class="ai-iphone-compat-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-iphone-compat__header-{{ ai_gen_id }}">
    {{ block.settings.header_text }}
  </div>
  
  <ul class="ai-iphone-compat__list-{{ ai_gen_id }}">
    {% if block.settings.show_iphone_16_pro_max %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 16 Pro Max</li>
    {% endif %}
    {% if block.settings.show_iphone_16_pro %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 16 Pro</li>
    {% endif %}
    {% if block.settings.show_iphone_16_plus %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 16 Plus</li>
    {% endif %}
    {% if block.settings.show_iphone_16 %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 16</li>
    {% endif %}
    {% if block.settings.show_iphone_15_pro_max %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 15 Pro Max</li>
    {% endif %}
    {% if block.settings.show_iphone_15_pro %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 15 Pro</li>
    {% endif %}
    {% if block.settings.show_iphone_15_plus %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 15 Plus</li>
    {% endif %}
    {% if block.settings.show_iphone_15 %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 15</li>
    {% endif %}
    {% if block.settings.show_iphone_14_pro_max %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 14 Pro Max</li>
    {% endif %}
    {% if block.settings.show_iphone_14_pro %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 14 Pro</li>
    {% endif %}
    {% if block.settings.show_iphone_14_plus %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 14 Plus</li>
    {% endif %}
    {% if block.settings.show_iphone_14 %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 14</li>
    {% endif %}
    {% if block.settings.show_iphone_13_series %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 13 Series</li>
    {% endif %}
    {% if block.settings.show_iphone_12_series %}
      <li class="ai-iphone-compat__item-{{ ai_gen_id }}">iPhone 12 Series</li>
    {% endif %}
  </ul>
  
  {% if block.settings.show_magsafe_footer %}
    <div class="ai-iphone-compat__footer-{{ ai_gen_id }}">
      {{ block.settings.footer_text }}
    </div>
  {% endif %}
</div>

