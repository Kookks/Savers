            "icon": "check_mark",
            "content": "<p>Compatible with all MagSafe-enabled iPhone models:</p><ul><li>iPhone 12, 12 Mini, 12 Pro, 12 Pro Max</li><li>iPhone 13, 13 Mini, 13 Pro, 13 Pro Max</li><li>iPhone 14, 14 Plus, 14 Pro, 14 Pro Max</li><li>iPhone 15, 15 Plus, 15 Pro, 15 Pro Max</li><li>iPhone 16, 16 Plus, 16 Pro, 16 Pro Max</li></ul><p><em>Requires MagSafe-compatible iPhone or MagSafe case.</em></p>"
          }
        },
