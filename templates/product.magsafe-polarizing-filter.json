        "faq_tab": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Common Questions",
            "icon": "chat_bubble",
            "content": "<details style=\"border-bottom:1px solid #e8e8e1;padding:10px 0;\"><summary style=\"font-weight:600;cursor:pointer;list-style:none;\">Will it work with my current iPhone case?</summary><p style=\"margin:8px 0 0;color:#555;font-size:14px;\">Yes — as long as your case is MagSafe-compatible (most modern cases are). The filter clicks directly onto the magnetic ring. If your case supports wireless charging alignment, it will work.</p></details><details style=\"border-bottom:1px solid #e8e8e1;padding:10px 0;\"><summary style=\"font-weight:600;cursor:pointer;list-style:none;\">Is this the same product I saw on Instagram?</summary><p style=\"margin:8px 0 0;color:#555;font-size:14px;\">Yes. SaversLeb is the exclusive seller in Lebanon. Same product, delivered locally — no customs fees, no 4-week wait, no risk.</p></details><details style=\"border-bottom:1px solid #e8e8e1;padding:10px 0;\"><summary style=\"font-weight:600;cursor:pointer;list-style:none;\">How do I pay?</summary><p style=\"margin:8px 0 0;color:#555;font-size:14px;\">Cash on delivery — you pay when it arrives at your door. No card required. You can also order directly via WhatsApp if you prefer.</p></details><details style=\"padding:10px 0;\"><summary style=\"font-weight:600;cursor:pointer;list-style:none;\">What if I don't like it?</summary><p style=\"margin:8px 0 0;color:#555;font-size:14px;\">Return it within 30 days for a full refund. No questions asked. We stand behind the product completely.</p></details>"
          }
        }
